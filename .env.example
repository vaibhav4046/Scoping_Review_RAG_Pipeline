# ============================================
# Scoping Review AI System — Environment Config
# ============================================

# --- Database ---
POSTGRES_USER=scopingreview
POSTGRES_PASSWORD=scopingreview_secret_2024
POSTGRES_DB=scoping_review_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT Auth ---
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEFAULT_ADMIN_EMAIL=admin@scopingreview.local
DEFAULT_ADMIN_PASSWORD=changeme123

# --- LLM Providers ---
# Ollama (local) — no key needed, just the base URL
OLLAMA_BASE_URL=http://ollama:11434

# Google Gemini (free tier: 60 req/min)
GEMINI_API_KEY=
# Groq (free tier: 30 req/min)
GROQ_API_KEY=

# Primary and validator model selection
PRIMARY_LLM_PROVIDER=gemini
PRIMARY_LLM_MODEL=gemini-2.0-flash
VALIDATOR_LLM_PROVIDER=groq
VALIDATOR_LLM_MODEL=llama-3.3-70b-versatile

# Embedding model (Ollama local)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# --- PubMed ---
PUBMED_EMAIL=your-email@example.com
PUBMED_RATE_LIMIT=3

# --- App ---
APP_NAME=Scoping Review AI
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads

# --- Vaibhav: ChromaDB (local vector store) ---
CHROMA_PERSIST_DIR=/app/data/chroma_db
VECTOR_STORE_BACKEND=pgvector
# Set to "chromadb" for local dev without PostgreSQL
